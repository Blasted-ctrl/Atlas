# ─── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── AI (required for recommendations) ─────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Next.js Web ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me-with-a-long-random-string

# ─── FastAPI ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=true
API_SECRET_KEY=replace-me-with-a-long-random-string
API_CORS_ORIGINS=http://localhost:3000

# ─── Database (PostgreSQL + pgvector) ───────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=atlas
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas_dev_password
DATABASE_URL=postgresql+asyncpg://atlas:atlas_dev_password@localhost:5432/atlas

# ─── Redis ───────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ─── Celery Worker ───────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_WORKER_CONCURRENCY=4

# ─── MinIO (S3-compatible) ───────────────────────────────────────────────────────
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=atlas_minio_root
MINIO_ROOT_PASSWORD=atlas_minio_password
MINIO_BUCKET_COSTS=atlas-cost-reports
MINIO_BUCKET_EXPORTS=atlas-exports
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=atlas_minio_root
S3_SECRET_ACCESS_KEY=atlas_minio_password
S3_REGION=us-east-1

# Observability
OTEL_ENABLED=true
OTEL_ENVIRONMENT=development
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
METRICS_ENABLED=true
METRICS_PATH=/metrics
WORKER_METRICS_PORT=9465

# ─── Cloud Providers ────────────────────────────────────────────────────────────
# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# GCP
GOOGLE_APPLICATION_CREDENTIALS=

# Azure
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=
